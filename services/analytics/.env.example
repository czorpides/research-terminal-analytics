# --- Service identity ---
SERVICE_VERSION=0.2.0
DEPLOY_ENV=local

# --- Shared-secret auth between Lovable/TanStack and this service ---
# Long random string; identical value must be stored server-side in the
# Lovable app as ANALYTICS_SERVICE_TOKEN. Never expose to the browser.
ANALYTICS_SERVICE_TOKEN=replace-with-long-random-string

# --- Optional ---
LOG_LEVEL=INFO
