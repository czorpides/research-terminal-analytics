# --- Service identity ---
SERVICE_VERSION=0.1.0
DEPLOY_ENV=local

# --- Shared-secret auth between TanStack and this service ---
# Long random string; identical value must be stored server-side in the
# TanStack app as ANALYTICS_SERVICE_TOKEN. Never expose to the browser.
ANALYTICS_SERVICE_TOKEN=replace-with-long-random-string

# --- Supabase (service role; server-only) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# --- Optional ---
LOG_LEVEL=INFO